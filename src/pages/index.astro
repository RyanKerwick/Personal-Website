---
import "../styles/global.css";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const items = await getCollection("sections");
const ordered = items.sort((a, b) => a.data.order - b.data.order);

const rendered = await Promise.all(
  ordered.map(async (entry, idx) => {
    const { Content } = await entry.render();
    return { entry, Content, index: idx };
  })
);

const pad = (n: number) => String(n).padStart(2, "0");
---

<BaseLayout title="Ryan Kerwick — Field Notes">
  <header class="topbar reveal" data-delay="1">
    <div class="topbar-inner">
      <a href="#home" class="brand">
        <span class="dot" aria-hidden="true"></span>
        Ryan Kerwick / Field&nbsp;Notes
      </a>
      <nav class="nav-links" aria-label="Primary">
        {ordered.map((e) => (
          <a href={`#${e.data.id ?? e.slug}`} class="nav-link">
            {e.data.title}
          </a>
        ))}
      </nav>
    </div>
  </header>

  <main class="page">
    {rendered.map(({ entry, Content, index }) => {
      const id = entry.data.id ?? entry.slug;
      const isHero = id === "home" || index === 0;

      if (isHero) {
        return (
          <section id={id} class="section hero">
            <span class="hero-stamp" aria-hidden="true">Vol. 01 · 2026</span>
            <Content />
          </section>
        );
      }

      return (
        <section id={id} class="section io-reveal">
          <div class="section-grid">
            <aside class="section-label">
              <span><span class="num">{pad(index + 1)}</span> &nbsp;/&nbsp; Section</span>
              <span>{entry.data.title}</span>
              <span class="rule" aria-hidden="true"></span>
            </aside>
            <div class="section-body">
              <Content />
            </div>
          </div>
        </section>
      );
    })}
  </main>

  <footer class="page site-footer">
    <span>© {new Date().getFullYear()} · Ryan Kerwick</span>
    <span class="colophon">
      Set in Fraunces &amp; JetBrains Mono. Built with Astro, Tailwind, and a
      great deal of coffee.
    </span>
    <span>Boulder, CO · 40.01°N 105.27°W</span>
  </footer>
</BaseLayout>
